 444+ 2941              //
 445+ 2941              // >far         ha -- a n
 446+ 2941              // decode bits 765 of H as one of the 8K-page between 64 and 71 (40h-47h)
 447+ 2941              // take lower bits of H and L as an offset from E000h
 448+ 2941              // then return address  a  between E000h-FFFFh
 449+ 2941              // and page number n  between 64-71 (40h-47h)
 450+ 2941              // For example, in hex:
 451+ 2941              //   0000 >FAR  gives  40.E000
 452+ 2941              //   1FFF >FAR  gives  40.FFFF
 453+ 2941              //   2000 >FAR  gives  41.E000
 454+ 2941              //   3FFF >FAR  gives  41.FFFF
 455+ 2941              //   EFFF >FAR  gives  47.EFFF
 456+ 2941              //   FFFF >FAR  gives  47.FFFF
 457+ 2941                              New_Def TO_FAR, ">FAR", is_code, is_normal
 457+ 2941             >
