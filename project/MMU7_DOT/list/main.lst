 184++23E0              // any/all of:
 185++23E0              //   esx_mode_read          $01 request read access
 186++23E0              //   esx_mode_write         $02 request write access
 187++23E0              //   esx_mode_use_header    $40 read/write +3DOS header
 188++23E0              // plus one of:
 189++23E0              //   esx_mode_open_exist    $00 only open existing file
 190++23E0              //   esx_mode_open_creat    $08 open existing or create file
 191++23E0              //   esx_mode_creat_noexist $04 create new file, error if exists
 192++23E0              //   esx_mode_creat_trunc   $0c create new file, delete existing
 193++23E0              // Return file-handle u and 0 on success, True flag on error
