 444+ 292C              //
 445+ 292C              // >far         ha -- a n
 446+ 292C              // decode bits 765 of H as one of the 8K-page between 64 and 71 (40h-47h)
 447+ 292C              // take lower bits of H and L as an offset from E000h
 448+ 292C              // then return address  a  between E000h-FFFFh
 449+ 292C              // and page number n  between 64-71 (40h-47h)
 450+ 292C              // For example, in hex:
 451+ 292C              //   0000 >FAR  gives  40.E000
 452+ 292C              //   1FFF >FAR  gives  40.FFFF
 453+ 292C              //   2000 >FAR  gives  41.E000
 454+ 292C              //   3FFF >FAR  gives  41.FFFF
 455+ 292C              //   EFFF >FAR  gives  47.EFFF
 456+ 292C              //   FFFF >FAR  gives  47.FFFF
 457+ 292C                              New_Def TO_FAR, ">FAR", is_code, is_normal
 457+ 292C             >
