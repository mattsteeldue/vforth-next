 182++23D7              // a2 is address to an 8-byte header data used in some cases.
 183++23D7              // b is access mode-byte, that is a combination of:
 184++23D7              // any/all of:
 185++23D7              //   esx_mode_read          $01 request read access
 186++23D7              //   esx_mode_write         $02 request write access
 187++23D7              //   esx_mode_use_header    $40 read/write +3DOS header
 188++23D7              // plus one of:
 189++23D7              //   esx_mode_open_exist    $00 only open existing file
 190++23D7              //   esx_mode_open_creat    $08 open existing or create file
 191++23D7              //   esx_mode_creat_noexist $04 create new file, error if exists
 192++23D7              //   esx_mode_creat_trunc   $0c create new file, delete existing
 193++23D7              // Return file-handle u and 0 on success, True flag on error
 194++23D7                              New_Def F_OPEN, "F_OPEN", is_code, is_normal
