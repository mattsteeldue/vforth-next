  43  0000              //  This is the complete compiler for v.Forth for SINCLAIR ZX Spectrum Next.
  44  0000              //  Each line of this source list mustn't exceed 80 bytes.
  45  0000              //  Z80N (ZX Spectrum Next) extension is available.
  46  0000              //
  47  0000              //  This list has been tested using the following configuration:
  48  0000              //      - CSpect emulator V.2.12.30
  49  0000              //  ______________________________________________________________________
  50  0000              //
  51  0000              //  Z80 Registers usage map
  52  0000              //
  53  0000              //  AF
  54  0000              //  BC - Instruction Pointer: should be preserved during ROM/OS calls
  55  0000              //  DE - Return Stack Pointer: should be preserved during ROM/OS calls
  56  0000              //  HL - Working
  57  0000              //
  58  0000              //  AF'- Sometime used for backup purpose
  59  0000              //  BC'- Not used
  60  0000              //  DE'- Not used
  61  0000              //  HL'- Not used
  62  0000              //
  63  0000              //  SP - Calculator Stack Pointer
  64  0000              //  IX - Inner interpreter "next" address pointer. This way jp (ix) is 2T-state faster than JP next
  65  0000              //  IY - (ZX System: must be preserved to interact with standard ROM)
  66  0000              //
  67  0000              //  ______________________________________________________________________
  68  0000              //
  69  0000              //  _________________
  70  0000              //
  71  0000              //  FORTH DEFINITIONS
  72  0000              //  _________________
  73  0000
  74  0000                              OPT     --zxnext
  75  0000              //  ______________________________________________________________________
  76  0000              //
  77  0000              // this controls some debugging code in L0.asm
  78  0000
  79  0000              //  1 for final .DOT binary release.
  80  0000
  81  0000              //  0 for debugging with Visual Studio Code and DeZog
  82  0000              // -1 for for binary comparison with Forth generated code.
  83  0000              DEBUGGING       equ     1   // .dot
  84  0000              //
  85  0000              //  ______________________________________________________________________
  86  0000
  87  0000                              if ( -1 == DEBUGGING )
  88  0000 ~            // ORIGIN          equ     $6366 - $80                 // for binary comparison with double compilation
  89  0000 ~            ORIGIN          equ     $9B21   -$80             // for binary comparison with single compilation
  90  0000 ~            Heap_Ptr        defl    $1F80                       // HP before compilation
  91  0000 ~            Heap_offset     defl    $2000
  92  0000 ~
  93  0000                              endif
  94  0000              //  ______________________________________________________________________
  95  0000
  96  0000                              if (  0 == DEBUGGING )
  97  0000 ~            ORIGIN          equ     $6366                   // binary and Tape
  98  0000 ~            // ORIGIN          equ     $9A93                // binary and Tape
  99  0000 ~            Heap_Ptr        defl    $0002
 100  0000 ~            Heap_offset     defl     0
 101  0000 ~
 102  0000                              endif
 103  0000              //  ______________________________________________________________________
 104  0000
 105  0000                              if (  1 == DEBUGGING )
 106  0000              ORIGIN          equ     $2000                   // for .dot
 107  0000              Heap_Ptr        defl    $0002
 108  0000              Heap_offset     defl     0
 109  0000
 110  0000                              endif
 111  0000              //  ______________________________________________________________________
 112  0000
 113  0000                              DEVICE  ZXSPECTRUMNEXT
 114  0000
 115  0000                              ORG     ORIGIN
 116  2000
 117  2000                              if ( -1 == DEBUGGING )
 118  2000 ~                            ds 128                            // for binary comparison
 119  2000                              endif
