 444+ 2938              //
 445+ 2938              // >far         ha -- a n
 446+ 2938              // decode bits 765 of H as one of the 8K-page between 64 and 71 (40h-47h)
 447+ 2938              // take lower bits of H and L as an offset from E000h
 448+ 2938              // then return address  a  between E000h-FFFFh
 449+ 2938              // and page number n  between 64-71 (40h-47h)
 450+ 2938              // For example, in hex:
 451+ 2938              //   0000 >FAR  gives  40.E000
 452+ 2938              //   1FFF >FAR  gives  40.FFFF
 453+ 2938              //   2000 >FAR  gives  41.E000
 454+ 2938              //   3FFF >FAR  gives  41.FFFF
 455+ 2938              //   EFFF >FAR  gives  47.EFFF
 456+ 2938              //   FFFF >FAR  gives  47.FFFF
 457+ 2938                              New_Def TO_FAR, ">FAR", is_code, is_normal
