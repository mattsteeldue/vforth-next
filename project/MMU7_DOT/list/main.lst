 178++23C7              //
 179++23C7              // f_open       a1 a2 b -- u f
 180++23C7              // open a file
 181++23C7              // a1 (filespec) is a null-terminated string, such as produced by ," definition
 182++23C7              // a2 is address to an 8-byte header data used in some cases.
 183++23C7              // b is access mode-byte, that is a combination of:
 184++23C7              // any/all of:
 185++23C7              //   esx_mode_read          $01 request read access
 186++23C7              //   esx_mode_write         $02 request write access
 187++23C7              //   esx_mode_use_header    $40 read/write +3DOS header
 188++23C7              // plus one of:
 189++23C7              //   esx_mode_open_exist    $00 only open existing file
 190++23C7              //   esx_mode_open_creat    $08 open existing or create file
 191++23C7              //   esx_mode_creat_noexist $04 create new file, error if exists
 192++23C7              //   esx_mode_creat_trunc   $0c create new file, delete existing
 193++23C7              // Return file-handle u and 0 on success, True flag on error
 194++23C7                              New_Def F_OPEN, "F_OPEN", is_code, is_normal
