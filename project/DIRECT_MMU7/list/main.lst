  56+ 783A              // m_p3dos      n1 n2 n3 n4 a -- n5 n6 n7 n8  f
  57+ 783A              // NextZXOS call wrapper.
  58+ 783A              //  n1 = hl register parameter value
  59+ 783A              //  n2 = de register parameter value
  60+ 783A              //  n3 = bc register parameter value
  61+ 783A              //  n4 =  a register parameter value
  62+ 783A              //   a = routine address in ROM 3
  63+ 783A              // ----
  64+ 783A              //  n5 = hl returned value
  65+ 783A              //  n6 = de returned value
