 242+ 6366              // USER_system:    equ     $D188               // User variables zone.
 243+ 6366              // FIRST_system:   equ     $D1E4               // Address of first BUFFER
 244+ 6366              // LIMIT_system:   equ     $E000               // Address of first byte beyond last BUFFER
